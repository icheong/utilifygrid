# Cloudflare Pages _headers file
# Controls cache, security headers, and content types

# HTML pages — short cache so updates deploy fast
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Sitemap — short cache so Google picks up new tools quickly
/sitemap.xml
  Cache-Control: public, max-age=3600

# Static assets — long cache (Astro adds content hashes to filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts & images
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=86400
