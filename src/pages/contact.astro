---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | UtilifyGrid"
  description="Get in touch with the UtilifyGrid team. Submit a tool suggestion, report a bug, or send a general enquiry."
  canonicalUrl="/contact"
>
  <div style="max-width:48rem; margin:0 auto; padding:3rem 1rem;">

    <h1 style="font-family:'Sora',sans-serif; font-size:2rem; font-weight:700; color:var(--text-primary); margin-bottom:0.5rem;">Contact Us</h1>
    <p style="font-size:0.875rem; color:var(--text-muted); margin-bottom:2.5rem;">We read every message — usually within 1–2 business days.</p>

    <div style="display:grid; grid-template-columns:1fr; gap:2rem;">

      <!-- Contact form -->
      <div style="background:var(--bg-surface); border:1.5px solid var(--border); border-radius:1rem; padding:1.75rem;">

        <div id="form-alert" style="display:none; margin-bottom:1.25rem;"></div>

        <div style="display:flex; flex-direction:column; gap:1.1rem;">

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;" class="contact-name-row">
            <div>
              <label style="display:block; font-size:0.8rem; font-weight:600; color:var(--text-secondary); margin-bottom:0.35rem;" for="c-name">Name</label>
              <input id="c-name" type="text" placeholder="Your name"
                style="width:100%; padding:0.65rem 0.875rem; border:1.5px solid var(--border); border-radius:0.625rem; background:var(--bg-surface-2); color:var(--text-primary); font-size:0.9rem; outline:none; box-sizing:border-box; transition:border-color 0.15s;"
                onfocus="this.style.borderColor='#1D4ED8';" onblur="this.style.borderColor='var(--border)';" />
            </div>
            <div>
              <label style="display:block; font-size:0.8rem; font-weight:600; color:var(--text-secondary); margin-bottom:0.35rem;" for="c-email">Email</label>
              <input id="c-email" type="email" placeholder="you@example.com"
                style="width:100%; padding:0.65rem 0.875rem; border:1.5px solid var(--border); border-radius:0.625rem; background:var(--bg-surface-2); color:var(--text-primary); font-size:0.9rem; outline:none; box-sizing:border-box; transition:border-color 0.15s;"
                onfocus="this.style.borderColor='#1D4ED8';" onblur="this.style.borderColor='var(--border)';" />
            </div>
          </div>

          <div>
            <label style="display:block; font-size:0.8rem; font-weight:600; color:var(--text-secondary); margin-bottom:0.35rem;" for="c-subject">Subject</label>
            <select id="c-subject"
              style="width:100%; padding:0.65rem 0.875rem; border:1.5px solid var(--border); border-radius:0.625rem; background:var(--bg-surface-2); color:var(--text-primary); font-size:0.9rem; outline:none; box-sizing:border-box; cursor:pointer; transition:border-color 0.15s;"
              onfocus="this.style.borderColor='#1D4ED8';" onblur="this.style.borderColor='var(--border)';">
              <option value="Tool suggestion">💡 Suggest a new tool</option>
              <option value="Bug report">🐛 Report a bug</option>
              <option value="General enquiry">💬 General enquiry</option>
              <option value="Advertising">📢 Advertising enquiry</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label style="display:block; font-size:0.8rem; font-weight:600; color:var(--text-secondary); margin-bottom:0.35rem;" for="c-message">Message</label>
            <textarea id="c-message" rows="5" placeholder="Tell us what's on your mind…"
              style="width:100%; padding:0.65rem 0.875rem; border:1.5px solid var(--border); border-radius:0.625rem; background:var(--bg-surface-2); color:var(--text-primary); font-size:0.9rem; outline:none; box-sizing:border-box; resize:vertical; line-height:1.6; transition:border-color 0.15s; font-family:'Inter',sans-serif;"
              onfocus="this.style.borderColor='#1D4ED8';" onblur="this.style.borderColor='var(--border)';"></textarea>
          </div>

          <button id="send-btn"
            style="align-self:flex-start; padding:0.7rem 2rem; background:#1D4ED8; color:#fff; border:none; border-radius:0.625rem; font-size:0.9rem; font-weight:600; cursor:pointer; transition:background 0.15s;"
            onmouseover="this.style.background='#1E3A8A';"
            onmouseout="this.style.background='#1D4ED8';">
            Send message
          </button>

        </div>
      </div>

      <!-- Direct contact info -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;" class="contact-cards">

        <div style="background:var(--bg-surface); border:1.5px solid var(--border); border-radius:0.875rem; padding:1.25rem;">
          <div style="font-size:1.5rem; margin-bottom:0.5rem;">✉️</div>
          <div style="font-family:'Sora',sans-serif; font-weight:600; color:var(--text-primary); font-size:0.9rem; margin-bottom:0.35rem;">Email us directly</div>
          <a href="mailto:contactus@utilifygrid.com" style="font-size:0.85rem; color:#1D4ED8; word-break:break-all;">contactus@utilifygrid.com</a>
        </div>

        <div style="background:var(--bg-surface); border:1.5px solid var(--border); border-radius:0.875rem; padding:1.25rem;">
          <div style="font-size:1.5rem; margin-bottom:0.5rem;">💡</div>
          <div style="font-family:'Sora',sans-serif; font-weight:600; color:var(--text-primary); font-size:0.9rem; margin-bottom:0.35rem;">Suggest a tool</div>
          <p style="font-size:0.85rem; color:var(--text-secondary); line-height:1.5; margin:0;">Have an idea for a tool we don't have yet? We'd love to hear it.</p>
        </div>

      </div>

    </div>
  </div>
</BaseLayout>

<style>
  @media (max-width: 500px) {
    .contact-name-row { grid-template-columns: 1fr !important; }
    .contact-cards    { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const nameEl    = document.getElementById('c-name')    as HTMLInputElement;
  const emailEl   = document.getElementById('c-email')   as HTMLInputElement;
  const subjectEl = document.getElementById('c-subject') as HTMLSelectElement;
  const messageEl = document.getElementById('c-message') as HTMLTextAreaElement;
  const sendBtn   = document.getElementById('send-btn')  as HTMLButtonElement;
  const alertEl   = document.getElementById('form-alert')!;

  function showAlert(msg: string, type: 'success' | 'error') {
    const bg     = type === 'success' ? '#F0FDF4' : '#FEF2F2';
    const border = type === 'success' ? '#BBF7D0' : '#FECACA';
    const color  = type === 'success' ? '#166534' : '#DC2626';
    const icon   = type === 'success' ? '✓' : '⚠';
    alertEl.innerHTML = `<div style="background:${bg}; border:1px solid ${border}; color:${color}; border-radius:0.5rem; padding:0.75rem 1rem; font-size:0.875rem;">${icon} ${msg}</div>`;
    alertEl.style.display = 'block';
  }

  sendBtn.addEventListener('click', () => {
    const name    = nameEl.value.trim();
    const email   = emailEl.value.trim();
    const subject = subjectEl.value;
    const message = messageEl.value.trim();

    if (!name) { showAlert('Please enter your name.', 'error'); return; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showAlert('Please enter a valid email address.', 'error'); return;
    }
    if (!message) { showAlert('Please enter a message.', 'error'); return; }

    const mailSubject = encodeURIComponent(`[UtilifyGrid] ${subject}`);
    const mailBody    = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\n${message}`);
    window.location.href = `mailto:contactus@utilifygrid.com?subject=${mailSubject}&body=${mailBody}`;

    showAlert('Your email client should open with the message pre-filled. If nothing happened, email us directly at contactus@utilifygrid.com.', 'success');
  });
</script>
