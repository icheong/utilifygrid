---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About UtilifyGrid – Free Browser-Based Tools"
  description="Learn about UtilifyGrid — a growing library of free, browser-based calculators, converters, and developer utilities. No accounts, no downloads, no data collection."
  canonicalUrl="/about"
>
  <div style="max-width:48rem; margin:0 auto; padding:3rem 1rem;">

    <h1 style="font-family:'Sora',sans-serif; font-size:2rem; font-weight:700; color:var(--text-primary); margin-bottom:0.5rem;">About UtilifyGrid</h1>
    <p style="font-size:0.875rem; color:var(--text-muted); margin-bottom:2.5rem;">Practical tools for everyday tasks</p>

    <div style="display:flex; flex-direction:column; gap:2rem;">

      <section>
        <h2 style="font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:600; color:var(--text-primary); margin-bottom:0.75rem;">What is UtilifyGrid?</h2>
        <p style="font-size:0.9rem; color:var(--text-secondary); line-height:1.75; margin-bottom:0.75rem;">
          UtilifyGrid is a growing library of free, browser-based tools built for developers, designers, writers, and anyone who needs a quick, accurate answer without the friction of signing up, downloading an app, or waiting for a server.
        </p>
        <p style="font-size:0.9rem; color:var(--text-secondary); line-height:1.75;">
          Every tool on this site — from health calculators and unit converters to JWT debuggers and CSS sandboxes — runs entirely in your browser using JavaScript. Nothing you type is ever sent to a server. Your data stays on your device.
        </p>
      </section>

      <section>
        <h2 style="font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:600; color:var(--text-primary); margin-bottom:0.75rem;">Why we built it</h2>
        <p style="font-size:0.9rem; color:var(--text-secondary); line-height:1.75; margin-bottom:0.75rem;">
          Most tools people search for online are simple enough to run in a browser tab — yet many sites still upload your input to a backend, require an account, or bury the tool under layers of ads and popups. We thought there was a better way.
        </p>
        <p style="font-size:0.9rem; color:var(--text-secondary); line-height:1.75;">
          UtilifyGrid is built on the principle that a tool should load instantly, work offline if needed, and never touch your data. We use Google AdSense to keep the site free — that's the only third-party service with access to any information about your visit.
        </p>
      </section>

      <section>
        <h2 style="font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:600; color:var(--text-primary); margin-bottom:0.75rem;">Accuracy & methodology</h2>
        <p style="font-size:0.9rem; color:var(--text-secondary); line-height:1.75;">
          Each tool is based on established formulas, published standards, or widely accepted conventions — WHO guidelines for health metrics, RFC specifications for developer tools, IEEE standards for unit conversions. Results are provided for informational purposes. For medical, financial, or legal decisions, always consult a qualified professional.
        </p>
      </section>

      <section>
        <h2 style="font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:600; color:var(--text-primary); margin-bottom:0.75rem;">Suggest a tool</h2>
        <p style="font-size:0.9rem; color:var(--text-secondary); line-height:1.75;">
          UtilifyGrid is actively growing. If there's a tool you reach for regularly that isn't here yet, we'd love to hear about it. Send your suggestion via our <a href="/contact" style="color:#1D4ED8;">contact page</a> and we'll consider it for a future release.
        </p>
      </section>

      <!-- Stat strip -->
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; background:var(--bg-surface-2); border:1px solid var(--border); border-radius:0.875rem; padding:1.5rem; text-align:center;">
        {[
          ['100%', 'Client-side'],
          ['0',    'Data collected'],
          ['Free', 'Always'],
        ].map(([val, label]) => (
          <div>
            <div style="font-family:'Sora',sans-serif; font-size:1.5rem; font-weight:700; color:#1D4ED8;">{val}</div>
            <div style="font-size:0.8rem; color:var(--text-muted); margin-top:0.2rem;">{label}</div>
          </div>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>
