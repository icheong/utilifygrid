---
import ToolLayout from '../../layouts/ToolLayout.astro';
import tools from '../../data/tools.json';

const tool = tools.find(t => t.slug === 'sql-to-nosql')!;
---

<ToolLayout tool={tool}>

  <!-- ═══ THE TOOL ═══ -->
  <div slot="tool">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; align-items:stretch;" id="converter-grid">
      
      <!-- SQL Input -->
      <div style="background:#fff; border:1px solid #E2E8F0; border-radius:1rem; display:flex; flex-direction:column; overflow:hidden; box-shadow:0 4px 6px -1px rgba(0,0,0,0.05);">
        <div style="background:#F8FAFC; border-bottom:1px solid #E2E8F0; padding:0.75rem 1.25rem; display:flex; justify-content:space-between; align-items:center;">
          <h3 style="margin:0; font-family:'Sora',sans-serif; font-size:0.95rem; font-weight:600; color:#0F172A; display:flex; align-items:center; gap:0.5rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#3B82F6;"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
            SQL Query
          </h3>
          <button id="btn-sample" style="background:#DBEAFE; color:#1D4ED8; border:none; border-radius:0.35rem; padding:0.3rem 0.6rem; font-size:0.75rem; font-weight:600; cursor:pointer; transition:background 0.2s;">
            Load Sample
          </button>
        </div>
        <textarea
          id="sql-input"
          placeholder="SELECT name, age, email&#10;FROM users&#10;WHERE age >= 18 AND status = 'active'&#10;ORDER BY created_at DESC&#10;LIMIT 50"
          style="flex:1; width:100%; min-height:350px; padding:1.25rem; border:none; resize:none; font-family:'Fira Code',monospace; font-size:0.9rem; color:#1E293B; line-height:1.6; outline:none;"
          spellcheck="false"
        ></textarea>
      </div>

      <!-- NoSQL Output -->
      <div style="background:#0F172A; border-radius:1rem; display:flex; flex-direction:column; overflow:hidden; box-shadow:0 4px 6px -1px rgba(0,0,0,0.1);">
        <div style="background:#1E293B; border-bottom:1px solid #334155; padding:0.75rem 1.25rem; display:flex; justify-content:space-between; align-items:center;">
          <h3 style="margin:0; font-family:'Sora',sans-serif; font-size:0.95rem; font-weight:600; color:#F8FAFC; display:flex; align-items:center; gap:0.5rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#10B981;"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            MongoDB Aggregation
          </h3>
          <button id="btn-copy" style="background:rgba(255,255,255,0.1); color:#F8FAFC; border:1px solid rgba(255,255,255,0.2); border-radius:0.35rem; padding:0.3rem 0.6rem; font-size:0.75rem; font-weight:600; cursor:pointer; transition:all 0.2s;">
            Copy Code
          </button>
        </div>
        <div style="flex:1; position:relative;">
          <pre style="margin:0; padding:1.25rem; width:100%; height:100%; overflow:auto; font-family:'Fira Code',monospace; font-size:0.9rem; color:#A7F3D0; line-height:1.6;" id="nosql-output"></pre>
          
          <div id="error-banner" style="display:none; position:absolute; bottom:0; left:0; right:0; background:#EF4444; color:white; font-size:0.85rem; font-weight:600; padding:0.75rem 1.25rem; border-top:1px solid #B91C1C;">
            Error parsing SQL query
          </div>
        </div>
      </div>

    </div>
  </div>

  <div slot="how-to-use">
    <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:700; color:#0F172A; margin-bottom:0.75rem;">
      How to use the Converter
    </h2>
    <p style="color:#475569; font-size:0.9rem; line-height:1.75; margin-bottom:0.75rem;">
      Simply paste your standard SQL query into the left-hand text area. The tool will automatically parse the syntax as you type and generate the equivalent MongoDB Aggregation Pipeline on the right.
    </p>
    <p style="color:#475569; font-size:0.9rem; line-height:1.75;">
      Click the <strong>"Load Sample"</strong> button to see an example of a query that includes <code style="background:#F1F5F9; padding:0.1rem 0.3rem; border-radius:0.25rem;">SELECT</code>, <code style="background:#F1F5F9; padding:0.1rem 0.3rem; border-radius:0.25rem;">FROM</code>, <code style="background:#F1F5F9; padding:0.1rem 0.3rem; border-radius:0.25rem;">WHERE</code>, <code style="background:#F1F5F9; padding:0.1rem 0.3rem; border-radius:0.25rem;">ORDER BY</code>, and <code style="background:#F1F5F9; padding:0.1rem 0.3rem; border-radius:0.25rem;">LIMIT</code> clauses. Once generated, click <strong>"Copy Code"</strong> to copy the ready-to-use JavaScript snippet for your Node.js or MongoDB shell environment.
    </p>
  </div>

  <div slot="how-it-works">
    <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:700; color:#0F172A; margin-bottom:0.75rem;">
      Supported Features & Limitations
    </h2>
    <p style="color:#475569; font-size:0.9rem; line-height:1.75; margin-bottom:1rem;">
      This tool uses a lightweight client-side parser designed for <strong>basic querying and learning purposes</strong>. It seamlessly maps relational SQL concepts to document-based NoSQL paradigms:
    </p>
    <ul style="color:#475569; font-size:0.9rem; line-height:1.75; padding-left:1.5rem; margin-bottom:1rem;">
      <li><code>SELECT a, b</code> &rarr; <code>$project: &#123; a: 1, b: 1 &#125;</code></li>
      <li><code>FROM users</code> &rarr; <code>db.users.aggregate(...)</code></li>
      <li><code>WHERE age >= 18</code> &rarr; <code>$match: &#123; age: &#123; $gte: 18 &#125; &#125;</code></li>
      <li><code>ORDER BY created_at DESC</code> &rarr; <code>$sort: &#123; created_at: -1 &#125;</code></li>
      <li><code>LIMIT 10</code> &rarr; <code>$limit: 10</code></li>
    </ul>
    <p style="color:#475569; font-size:0.9rem; line-height:1.75;">
      <em>Note: Complex nested subqueries, advanced JOIN operations, and aggregate functions (like SUM or AVG) require deeper AST mapping and may not perfectly translate using this lightweight utility.</em>
    </p>
  </div>

</ToolLayout>

<script>
  const sqlInput = document.getElementById('sql-input') as HTMLTextAreaElement;
  const nosqlOutput = document.getElementById('nosql-output')!;
  const btnSample = document.getElementById('btn-sample')!;
  const btnCopy = document.getElementById('btn-copy')!;
  const errorBanner = document.getElementById('error-banner')!;

  const SAMPLE_QUERY = `SELECT name, email, status, age\nFROM users\nWHERE status = 'active' AND age >= 18\nORDER BY created_at DESC\nLIMIT 50`;

  function parseSQLToMongo(query: string) {
    let pipeline: string[] = [];
    let collection = "unknown_collection";
    
    // Normalize and remove comments
    let q = query.replace(/--.*$/gm, '').replace(/\/\*[\s\S]*?\*\//g, '');
    q = q.replace(/\s+/g, ' ').trim().replace(/;$/, '');
    
    if (!q) return "";

    const parts = q.split(/\b(SELECT|FROM|WHERE|GROUP BY|ORDER BY|LIMIT)\b/i);
    
    let clauses: Record<string, string> = {};
    let currentClause = null;
    
    for(let i=0; i<parts.length; i++) {
       const part = parts[i].trim();
       if (!part) continue;
       const upper = part.toUpperCase();
       if (['SELECT', 'FROM', 'WHERE', 'GROUP BY', 'ORDER BY', 'LIMIT'].includes(upper)) {
          currentClause = upper;
          clauses[currentClause] = "";
       } else if (currentClause) {
          clauses[currentClause] += part + " ";
       }
    }

    for (let k in clauses) clauses[k] = clauses[k].trim();

    if (!clauses['SELECT'] && !clauses['FROM']) {
        throw new Error("Missing SELECT or FROM clause");
    }

    if (clauses['FROM']) {
      collection = clauses['FROM'];
    }

    // WHERE -> $match
    if (clauses['WHERE']) {
       let conditions = clauses['WHERE'].split(/\bAND\b/i).map(s => s.trim());
       let matchObj: any = {};
       
       conditions.forEach(cond => {
          let match = cond.match(/^([\w\.]+)\s*(=|!=|>|<|>=|<=)\s*(.+)$/);
          if (match) {
             let field = match[1];
             let op = match[2];
             let val: any = match[3];
             
             // parse value
             if (val.match(/^['"].*['"]$/)) {
               val = val.slice(1, -1);
             } else if (!isNaN(Number(val))) {
               val = Number(val);
             } else if (val.toLowerCase() === 'true') {
               val = true;
             } else if (val.toLowerCase() === 'false') {
               val = false;
             }
             
             if (op === '=') matchObj[field] = val;
             else if (op === '!=') matchObj[field] = { $ne: val };
             else if (op === '>') matchObj[field] = { $gt: val };
             else if (op === '<') matchObj[field] = { $lt: val };
             else if (op === '>=') matchObj[field] = { $gte: val };
             else if (op === '<=') matchObj[field] = { $lte: val };
          } else {
             // fallback for unparsed condition
             matchObj[cond] = "UNPARSED_CONDITION";
          }
       });
       pipeline.push(`  { $match: ${JSON.stringify(matchObj)} }`);
    }

    // ORDER BY -> $sort
    if (clauses['ORDER BY']) {
       let sorts = clauses['ORDER BY'].split(',').map(s => s.trim());
       let sortObj: any = {};
       sorts.forEach(s => {
          let parts = s.split(/\s+/);
          let field = parts[0];
          let dir = (parts[1] && parts[1].toUpperCase() === 'DESC') ? -1 : 1;
          sortObj[field] = dir;
       });
       pipeline.push(`  { $sort: ${JSON.stringify(sortObj)} }`);
    }
    
    // LIMIT -> $limit
    if (clauses['LIMIT']) {
       let l = parseInt(clauses['LIMIT']);
       if (!isNaN(l)) pipeline.push(`  { $limit: ${l} }`);
    }

    // SELECT -> $project
    if (clauses['SELECT'] && clauses['SELECT'] !== '*') {
       let fields = clauses['SELECT'].split(',').map(s => s.trim());
       let projObj: any = {};
       fields.forEach(f => {
         if (f) projObj[f] = 1;
       });
       pipeline.push(`  { $project: ${JSON.stringify(projObj)} }`);
    }

    // format output
    let out = `db.${collection}.aggregate([\n`;
    // Clean up quotes around keys for better JS aesthetics
    let formattedPipeline = pipeline.join(',\n').replace(/"([^"]+)":/g, '$1:');
    
    // Fix $ operators needing quotes in pure JSON? No, JS objects don't strictly need them
    // but Prettier might prefer it. We'll leave them as $match, etc.
    
    out += formattedPipeline;
    out += `\n]);`;

    return out;
  }

  function handleConvert() {
    const val = sqlInput.value;
    if (!val.trim()) {
      nosqlOutput.innerText = '// Waiting for input...\n// Start typing SQL on the left.';
      errorBanner.style.display = 'none';
      return;
    }
    
    try {
      const result = parseSQLToMongo(val);
      nosqlOutput.innerText = result;
      errorBanner.style.display = 'none';
    } catch (err: any) {
      errorBanner.innerText = `Error: ${err.message || 'Invalid SQL syntax'}`;
      errorBanner.style.display = 'block';
    }
  }

  // Events
  sqlInput.addEventListener('input', handleConvert);

  btnSample.addEventListener('click', () => {
    sqlInput.value = SAMPLE_QUERY;
    handleConvert();
  });

  btnCopy.addEventListener('click', () => {
    if (!nosqlOutput.innerText.startsWith('db.')) return;
    navigator.clipboard.writeText(nosqlOutput.innerText);
    const og = btnCopy.innerText;
    btnCopy.innerText = 'Copied!';
    btnCopy.style.background = 'rgba(16, 185, 129, 0.2)';
    btnCopy.style.borderColor = 'rgba(16, 185, 129, 0.5)';
    btnCopy.style.color = '#10B981';
    
    setTimeout(() => {
      btnCopy.innerText = og;
      btnCopy.style.background = 'rgba(255,255,255,0.1)';
      btnCopy.style.borderColor = 'rgba(255,255,255,0.2)';
      btnCopy.style.color = '#F8FAFC';
    }, 2000);
  });

  // Init
  handleConvert();
</script>

<style>
  @media (max-width: 768px) {
    #converter-grid {
      grid-template-columns: 1fr !important;
    }
    #sql-input {
      min-height: 250px !important;
    }
  }
</style>
