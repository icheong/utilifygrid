---
import ToolLayout from '../../layouts/ToolLayout.astro';
import tools from '../../data/tools.json';

const tool = tools.find(t => t.slug === 'freelance-rate-calculator')!;
---

<ToolLayout tool={tool}>

  <!-- ═══ THE TOOL ═══ -->
  <div slot="tool">
    
    <!-- Dashboard / Results -->
    <div style="background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%); border-radius:1rem; padding:2rem; margin-bottom:1.5rem; display:flex; flex-direction:column; gap:1.5rem; box-shadow:0 10px 25px -5px rgba(0,0,0,0.1);">
      <h2 style="margin:0; font-family:'Sora',sans-serif; font-size:1.1rem; color:#94A3B8; text-transform:uppercase; letter-spacing:0.05em; text-align:center;">
        Required Billing Rates
      </h2>
      
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:1.5rem;">
        
        <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; padding:1.5rem; text-align:center;">
          <div style="font-size:0.85rem; font-weight:600; color:#38BDF8; margin-bottom:0.5rem; text-transform:uppercase; letter-spacing:0.05em;">Hourly Rate</div>
          <div id="out-hourly" style="font-family:'Sora',sans-serif; font-size:2.5rem; font-weight:700; color:#F8FAFC; line-height:1;">$0</div>
        </div>

        <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; padding:1.5rem; text-align:center;">
          <div style="font-size:0.85rem; font-weight:600; color:#A78BFA; margin-bottom:0.5rem; text-transform:uppercase; letter-spacing:0.05em;">Daily Rate <span style="font-size:0.7rem; color:#94A3B8; text-transform:none;">(8 hrs)</span></div>
          <div id="out-daily" style="font-family:'Sora',sans-serif; font-size:2.5rem; font-weight:700; color:#F8FAFC; line-height:1;">$0</div>
        </div>

      </div>

      <div style="display:flex; justify-content:space-around; flex-wrap:wrap; gap:1rem; border-top:1px solid rgba(255,255,255,0.1); padding-top:1rem; margin-top:0.5rem;">
        <div style="text-align:center;">
          <div style="font-size:0.75rem; color:#94A3B8;">Gross Revenue Required</div>
          <div id="out-revenue" style="font-family:'Fira Code',monospace; font-size:1rem; color:#E2E8F0; font-weight:600;">$0</div>
        </div>
        <div style="text-align:center;">
          <div style="font-size:0.75rem; color:#94A3B8;">Total Billable Hours / Yr</div>
          <div id="out-hours" style="font-family:'Fira Code',monospace; font-size:1rem; color:#E2E8F0; font-weight:600;">0 hrs</div>
        </div>
      </div>
    </div>

    <!-- Inputs -->
    <div style="display:grid; grid-template-columns:1fr; gap:1.25rem;">
      
      <!-- Target Pay -->
      <div class="control-card" style="background:#fff; border:1px solid #E2E8F0; border-radius:1rem; padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <label style="font-family:'Sora',sans-serif; font-weight:600; color:#0F172A; display:flex; align-items:center; gap:0.5rem;">
            <span style="background:#DBEAFE; color:#1D4ED8; padding:0.25rem 0.5rem; border-radius:0.25rem; font-size:0.75rem;">1</span> Target Annual Take-Home Pay
          </label>
          <div style="display:flex; align-items:center; background:#F8FAFC; border:1px solid #CBD5E1; border-radius:0.5rem; overflow:hidden;">
            <span style="padding:0.4rem 0.6rem; background:#E2E8F0; color:#475569; font-weight:600;">$</span>
            <input type="number" id="in-takehome-num" value="70000" min="10000" max="500000" style="border:none; padding:0.4rem; font-family:'Inter',sans-serif; font-weight:600; color:#0F172A; width:90px; outline:none; background:transparent;">
          </div>
        </div>
        <input type="range" id="in-takehome" min="10000" max="500000" step="5000" value="70000" style="width:100%; accent-color:#1D4ED8;">
        <div style="font-size:0.8rem; color:#64748B;">How much money do you actually want in your bank account after all taxes and expenses are paid?</div>
      </div>

      <!-- Tax Rate -->
      <div class="control-card" style="background:#fff; border:1px solid #E2E8F0; border-radius:1rem; padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <label style="font-family:'Sora',sans-serif; font-weight:600; color:#0F172A; display:flex; align-items:center; gap:0.5rem;">
            <span style="background:#FCE7F3; color:#BE185D; padding:0.25rem 0.5rem; border-radius:0.25rem; font-size:0.75rem;">2</span> Income Tax & Deductions
          </label>
          <div style="display:flex; align-items:center; background:#F8FAFC; border:1px solid #CBD5E1; border-radius:0.5rem; overflow:hidden;">
            <input type="number" id="in-tax-num" value="30" min="0" max="70" style="border:none; padding:0.4rem; font-family:'Inter',sans-serif; font-weight:600; color:#0F172A; width:60px; text-align:right; outline:none; background:transparent;">
            <span style="padding:0.4rem 0.6rem; background:#E2E8F0; color:#475569; font-weight:600;">%</span>
          </div>
        </div>
        <input type="range" id="in-tax" min="0" max="70" step="1" value="30" style="width:100%; accent-color:#BE185D;">
        <div style="font-size:0.8rem; color:#64748B;">Your estimated effective tax rate, plus any mandatory social security or healthcare levies.</div>
      </div>

      <!-- Expenses -->
      <div class="control-card" style="background:#fff; border:1px solid #E2E8F0; border-radius:1rem; padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <label style="font-family:'Sora',sans-serif; font-weight:600; color:#0F172A; display:flex; align-items:center; gap:0.5rem;">
            <span style="background:#FEF3C7; color:#B45309; padding:0.25rem 0.5rem; border-radius:0.25rem; font-size:0.75rem;">3</span> Annual Business Expenses
          </label>
          <div style="display:flex; align-items:center; background:#F8FAFC; border:1px solid #CBD5E1; border-radius:0.5rem; overflow:hidden;">
            <span style="padding:0.4rem 0.6rem; background:#E2E8F0; color:#475569; font-weight:600;">$</span>
            <input type="number" id="in-expenses-num" value="10000" min="0" max="100000" style="border:none; padding:0.4rem; font-family:'Inter',sans-serif; font-weight:600; color:#0F172A; width:90px; outline:none; background:transparent;">
          </div>
        </div>
        <input type="range" id="in-expenses" min="0" max="100000" step="500" value="10000" style="width:100%; accent-color:#B45309;">
        <div style="font-size:0.8rem; color:#64748B;">Software subscriptions, hardware, insurance, accounting fees, hosting, travel, etc.</div>
      </div>

      <!-- Time Off -->
      <div class="control-card" style="background:#fff; border:1px solid #E2E8F0; border-radius:1rem; padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <label style="font-family:'Sora',sans-serif; font-weight:600; color:#0F172A; display:flex; align-items:center; gap:0.5rem;">
            <span style="background:#DCFCE7; color:#15803D; padding:0.25rem 0.5rem; border-radius:0.25rem; font-size:0.75rem;">4</span> Weeks Off Per Year
          </label>
          <div style="display:flex; align-items:center; background:#F8FAFC; border:1px solid #CBD5E1; border-radius:0.5rem; overflow:hidden;">
            <input type="number" id="in-weeksoff-num" value="4" min="0" max="52" style="border:none; padding:0.4rem; font-family:'Inter',sans-serif; font-weight:600; color:#0F172A; width:60px; text-align:right; outline:none; background:transparent;">
            <span style="padding:0.4rem 0.6rem; background:#E2E8F0; color:#475569; font-weight:600;">wks</span>
          </div>
        </div>
        <input type="range" id="in-weeksoff" min="0" max="52" step="1" value="4" style="width:100%; accent-color:#15803D;">
        <div style="font-size:0.8rem; color:#64748B;">Vacation time, public holidays, sick days. Remember, freelancers don't get paid time off!</div>
      </div>

      <!-- Billable Hours -->
      <div class="control-card" style="background:#fff; border:1px solid #E2E8F0; border-radius:1rem; padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <label style="font-family:'Sora',sans-serif; font-weight:600; color:#0F172A; display:flex; align-items:center; gap:0.5rem;">
            <span style="background:#F3E8FF; color:#7E22CE; padding:0.25rem 0.5rem; border-radius:0.25rem; font-size:0.75rem;">5</span> Billable Hours Per Week
          </label>
          <div style="display:flex; align-items:center; background:#F8FAFC; border:1px solid #CBD5E1; border-radius:0.5rem; overflow:hidden;">
            <input type="number" id="in-billable-num" value="25" min="1" max="80" style="border:none; padding:0.4rem; font-family:'Inter',sans-serif; font-weight:600; color:#0F172A; width:60px; text-align:right; outline:none; background:transparent;">
            <span style="padding:0.4rem 0.6rem; background:#E2E8F0; color:#475569; font-weight:600;">hrs</span>
          </div>
        </div>
        <input type="range" id="in-billable" min="1" max="80" step="1" value="25" style="width:100%; accent-color:#7E22CE;">
        <div style="font-size:0.8rem; color:#64748B;">Hours you can actually charge clients for. Admin, marketing, and emails are usually unbillable. (Average is 20-30 hrs).</div>
      </div>

    </div>
  </div>

  <div slot="how-to-use">
    <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:700; color:#0F172A; margin-bottom:0.75rem;">
      How to use the Rate Calculator
    </h2>
    <p style="color:#475569; font-size:0.9rem; line-height:1.75; margin-bottom:0.75rem;">
      Adjust the sliders or type directly into the input boxes to map out your specific financial situation. The dashboard at the top will instantly calculate the hourly and daily billing rates you need to charge clients to meet your target take-home pay.
    </p>
    <p style="color:#475569; font-size:0.9rem; line-height:1.75;">
      Be brutally honest with your estimates. Many new freelancers vastly underestimate their business expenses and vastly overestimate how many hours a week they can actually bill.
    </p>
  </div>

  <div slot="how-it-works">
    <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:700; color:#0F172A; margin-bottom:0.75rem;">
      The Math Behind the Rates
    </h2>
    <p style="color:#475569; font-size:0.9rem; line-height:1.75; margin-bottom:1rem;">
      Unlike a salaried employee, a freelancer must cover their own taxes, expenses, and unpaid time off. Here is how the calculator determines your rate:
    </p>
    <ul style="color:#475569; font-size:0.9rem; line-height:1.75; padding-left:1.5rem; margin-bottom:1rem;">
      <li><strong>Gross Income Required:</strong> <code>Target Take Home / (1 - Tax Rate)</code>. If you want $70,000 and pay 30% tax, you need to earn $100,000 before taxes.</li>
      <li><strong>Total Revenue Required:</strong> <code>Gross Income + Business Expenses</code>. This is the total money your business must bring in.</li>
      <li><strong>Total Billable Hours:</strong> <code>(52 Weeks - Weeks Off) × Billable Hours Per Week</code>. This tells us exactly how many hours per year you have available to generate the revenue.</li>
      <li><strong>Hourly Rate:</strong> <code>Total Revenue / Total Billable Hours</code>.</li>
      <li><strong>Daily Rate:</strong> Assumes a standard 8-hour billable day (<code>Hourly Rate × 8</code>).</li>
    </ul>
  </div>

</ToolLayout>

<script>
  // UI Elements
  const outHourly = document.getElementById('out-hourly')!;
  const outDaily = document.getElementById('out-daily')!;
  const outRevenue = document.getElementById('out-revenue')!;
  const outHours = document.getElementById('out-hours')!;

  // Inputs (Sliders and Number fields)
  const inputs = {
    takehome: { s: document.getElementById('in-takehome') as HTMLInputElement, n: document.getElementById('in-takehome-num') as HTMLInputElement },
    tax: { s: document.getElementById('in-tax') as HTMLInputElement, n: document.getElementById('in-tax-num') as HTMLInputElement },
    expenses: { s: document.getElementById('in-expenses') as HTMLInputElement, n: document.getElementById('in-expenses-num') as HTMLInputElement },
    weeksoff: { s: document.getElementById('in-weeksoff') as HTMLInputElement, n: document.getElementById('in-weeksoff-num') as HTMLInputElement },
    billable: { s: document.getElementById('in-billable') as HTMLInputElement, n: document.getElementById('in-billable-num') as HTMLInputElement }
  };

  const fmtCurrency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
  const fmtCurrencyDec = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const fmtNum = new Intl.NumberFormat('en-US');

  function calculate() {
    const takeHome = parseFloat(inputs.takehome.n.value) || 0;
    const taxRate = (parseFloat(inputs.tax.n.value) || 0) / 100;
    const expenses = parseFloat(inputs.expenses.n.value) || 0;
    const weeksOff = parseFloat(inputs.weeksoff.n.value) || 0;
    const billablePerWeek = parseFloat(inputs.billable.n.value) || 0;

    // Avoid division by zero if tax is 100%
    const grossRequired = taxRate >= 1 ? 0 : takeHome / (1 - taxRate);
    const totalRevenue = grossRequired + expenses;
    
    const workingWeeks = Math.max(0, 52 - weeksOff);
    const totalBillableHours = workingWeeks * billablePerWeek;

    // Avoid division by zero
    const hourlyRate = totalBillableHours > 0 ? totalRevenue / totalBillableHours : 0;
    const dailyRate = hourlyRate * 8; // standard 8 hr day

    // Update UI
    outHourly.innerText = fmtCurrencyDec.format(hourlyRate);
    outDaily.innerText = fmtCurrencyDec.format(dailyRate);
    outRevenue.innerText = fmtCurrency.format(totalRevenue);
    outHours.innerText = `${fmtNum.format(totalBillableHours)} hrs`;
  }

  // Bind events to sync sliders and number inputs
  Object.values(inputs).forEach(({ s, n }) => {
    s.addEventListener('input', () => {
      n.value = s.value;
      calculate();
    });
    n.addEventListener('input', () => {
      // Basic bounds clamping for number inputs visually
      let val = parseFloat(n.value) || 0;
      let min = parseFloat(s.min);
      let max = parseFloat(s.max);
      if (val < min) val = min;
      if (val > max) val = max;
      s.value = val.toString();
      calculate();
    });
  });

  // Init
  calculate();
</script>
