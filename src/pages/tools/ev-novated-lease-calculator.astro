---
import ToolLayout from '../../layouts/ToolLayout.astro';
import tools from '../../data/tools.json';

const tool = tools.find(t => t.slug === 'ev-novated-lease-calculator')!;
---

<ToolLayout tool={tool}>

  <!-- ═══ THE TOOL ═══ -->
  <div slot="tool">

    <p style="font-size:0.82rem; color:var(--text-muted); margin-bottom:1.25rem; padding:0.6rem 0.875rem; background:var(--bg-surface-2); border-radius:0.5rem; border-left:3px solid #F59E0B;">
      🇦🇺 Based on Australian tax rules including the <strong style="color:var(--text-primary);">FBT exemption for eligible EVs</strong> under the Treasury Laws Amendment (Electric Car Discount) Act 2022. Results are estimates only — consult a financial adviser before entering a lease.
    </p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;" class="ev-grid">

      <!-- ── LEFT: INPUTS ── -->
      <div style="display:flex; flex-direction:column; gap:1rem;">

        <div style="font-size:0.72rem; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.07em;">Your situation</div>

        <div class="ev-field">
          <label class="ev-label" for="gross-salary">Annual gross salary (before tax)</label>
          <div class="ev-input-wrap">
            <span class="ev-prefix">$</span>
            <input id="gross-salary" type="number" value="100000" min="1" class="ev-input" />
          </div>
        </div>

        <div class="ev-field">
          <label class="ev-label" for="vehicle-price">Vehicle price (drive-away)</label>
          <div class="ev-input-wrap">
            <span class="ev-prefix">$</span>
            <input id="vehicle-price" type="number" value="65000" min="1" class="ev-input" />
          </div>
        </div>

        <div class="ev-field">
          <label class="ev-label" for="lease-term">Lease term</label>
          <select id="lease-term" class="ev-select">
            <option value="1">1 year</option>
            <option value="2">2 years</option>
            <option value="3" selected>3 years</option>
            <option value="4">4 years</option>
            <option value="5">5 years</option>
          </select>
        </div>

        <div class="ev-field">
          <label class="ev-label" for="annual-km">Annual kilometres driven</label>
          <select id="annual-km" class="ev-select">
            <option value="10000">10,000 km/yr</option>
            <option value="15000" selected>15,000 km/yr</option>
            <option value="20000">20,000 km/yr</option>
            <option value="25000">25,000 km/yr</option>
            <option value="30000">30,000 km/yr</option>
          </select>
        </div>

        <div class="ev-field">
          <label class="ev-label" for="interest-rate">Novated lease interest rate (%)</label>
          <div class="ev-input-wrap">
            <input id="interest-rate" type="number" value="6.5" min="0" max="30" step="0.1" class="ev-input" style="padding-left:0.875rem;" />
            <span class="ev-suffix">%</span>
          </div>
        </div>

        <div class="ev-field">
          <label class="ev-label" for="residual-pct">Residual value (%)</label>
          <select id="residual-pct" class="ev-select">
            <option value="46.88">1 yr — 46.88%</option>
            <option value="37.5">2 yr — 37.5%</option>
            <option value="28.13" selected>3 yr — 28.13%</option>
            <option value="18.75">4 yr — 18.75%</option>
            <option value="0">5 yr — 0% (balloon)</option>
          </select>
        </div>

        <div style="padding-top:0.5rem; border-top:1px solid var(--border);">
          <div style="font-size:0.72rem; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.07em; margin-bottom:0.75rem;">Running costs (annual estimates)</div>

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
            <div class="ev-field">
              <label class="ev-label" for="fuel-cost">Charging / fuel ($/yr)</label>
              <div class="ev-input-wrap">
                <span class="ev-prefix">$</span>
                <input id="fuel-cost" type="number" value="800" min="0" class="ev-input" />
              </div>
            </div>
            <div class="ev-field">
              <label class="ev-label" for="insurance-cost">Insurance ($/yr)</label>
              <div class="ev-input-wrap">
                <span class="ev-prefix">$</span>
                <input id="insurance-cost" type="number" value="1800" min="0" class="ev-input" />
              </div>
            </div>
            <div class="ev-field">
              <label class="ev-label" for="service-cost">Servicing ($/yr)</label>
              <div class="ev-input-wrap">
                <span class="ev-prefix">$</span>
                <input id="service-cost" type="number" value="600" min="0" class="ev-input" />
              </div>
            </div>
            <div class="ev-field">
              <label class="ev-label" for="reg-cost">Rego &amp; CTP ($/yr)</label>
              <div class="ev-input-wrap">
                <span class="ev-prefix">$</span>
                <input id="reg-cost" type="number" value="900" min="0" class="ev-input" />
              </div>
            </div>
          </div>
        </div>

        <button id="calc-btn"
          style="padding:0.75rem; background:#1D4ED8; color:#fff; border:none; border-radius:0.625rem; font-size:0.9rem; font-weight:600; cursor:pointer; transition:background 0.15s; margin-top:0.25rem;"
          onmouseover="this.style.background='#1E3A8A';"
          onmouseout="this.style.background='#1D4ED8';">
          Calculate savings
        </button>

      </div>

      <!-- ── RIGHT: RESULTS ── -->
      <div id="results-panel" style="display:flex; flex-direction:column; gap:1rem;">

        <!-- Empty state -->
        <div id="empty-state" style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; min-height:300px; text-align:center; color:var(--text-muted); border:2px dashed var(--border); border-radius:0.875rem; padding:2rem;">
          <div style="font-size:2.5rem; margin-bottom:0.75rem;">🚗</div>
          <p style="font-size:0.875rem;">Fill in your details and click<br/><strong style="color:var(--text-secondary);">Calculate savings</strong></p>
        </div>

        <!-- Results -->
        <div id="results-content" style="display:none; flex-direction:column; gap:0.875rem;">

          <!-- Verdict banner -->
          <div id="verdict-banner" style="border-radius:0.875rem; padding:1.1rem 1.25rem; text-align:center;">
            <div id="verdict-label" style="font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; margin-bottom:0.3rem;"></div>
            <div id="verdict-amount" style="font-family:'Sora',sans-serif; font-size:2rem; font-weight:800; line-height:1;"></div>
            <div id="verdict-sub" style="font-size:0.8rem; margin-top:0.35rem; opacity:0.8;"></div>
          </div>

          <!-- Side-by-side summary -->
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.625rem;">

            <div style="background:var(--bg-surface-2); border:1.5px solid var(--border); border-radius:0.75rem; padding:1rem;">
              <div style="font-size:0.72rem; font-weight:700; color:#1D4ED8; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.6rem;">🔵 Novated Lease</div>
              <div class="res-row"><span class="res-lbl">Pre-tax lease cost</span><span class="res-val" id="r-lease-pretax"></span></div>
              <div class="res-row"><span class="res-lbl">Post-tax running</span><span class="res-val" id="r-lease-running"></span></div>
              <div class="res-row"><span class="res-lbl">GST savings</span><span class="res-val green" id="r-gst-saving"></span></div>
              <div class="res-row" style="border-top:1px solid var(--border); margin-top:0.4rem; padding-top:0.4rem;">
                <span class="res-lbl" style="font-weight:700; color:var(--text-primary);">Total out-of-pocket</span>
                <span class="res-val" style="font-weight:700; color:var(--text-primary);" id="r-lease-total"></span>
              </div>
            </div>

            <div style="background:var(--bg-surface-2); border:1.5px solid var(--border); border-radius:0.75rem; padding:1rem;">
              <div style="font-size:0.72rem; font-weight:700; color:#EA580C; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.6rem;">🟠 Out-of-Pocket</div>
              <div class="res-row"><span class="res-lbl">Loan repayments</span><span class="res-val" id="r-cash-loan"></span></div>
              <div class="res-row"><span class="res-lbl">Running costs</span><span class="res-val" id="r-cash-running"></span></div>
              <div class="res-row"><span class="res-lbl">Tax savings (none)</span><span class="res-val" id="r-cash-tax">—</span></div>
              <div class="res-row" style="border-top:1px solid var(--border); margin-top:0.4rem; padding-top:0.4rem;">
                <span class="res-lbl" style="font-weight:700; color:var(--text-primary);">Total out-of-pocket</span>
                <span class="res-val" style="font-weight:700; color:var(--text-primary);" id="r-cash-total"></span>
              </div>
            </div>

          </div>

          <!-- Tax breakdown -->
          <div style="background:var(--bg-surface-2); border:1.5px solid var(--border); border-radius:0.75rem; padding:1rem;">
            <div style="font-size:0.72rem; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.75rem;">Tax &amp; take-home breakdown (annual)</div>
            <div class="res-row"><span class="res-lbl">Gross salary</span><span class="res-val" id="r-gross"></span></div>
            <div class="res-row"><span class="res-lbl">Novated lease pre-tax deduction</span><span class="res-val red" id="r-pretax-ded"></span></div>
            <div class="res-row"><span class="res-lbl">Taxable income (with lease)</span><span class="res-val" id="r-taxable"></span></div>
            <div class="res-row"><span class="res-lbl">Income tax saved per year</span><span class="res-val green" id="r-tax-saved"></span></div>
            <div class="res-row"><span class="res-lbl">FBT liability</span><span class="res-val green" id="r-fbt">$0 (EV exempt)</span></div>
            <div class="res-row"><span class="res-lbl">GST saving (vehicle purchase)</span><span class="res-val green" id="r-gst2"></span></div>
          </div>

          <p style="font-size:0.73rem; color:var(--text-muted); line-height:1.6; padding:0.6rem 0.75rem; background:var(--bg-surface-2); border-radius:0.5rem;">
            Assumes 2024–25 Australian individual income tax rates including 2% Medicare levy. FBT exempt under the Electric Car Discount Act for vehicles under the luxury car tax threshold ($91,387 for 2024–25). GST saving assumes the employer claims ITC on vehicle. Residual values based on ATO effective life guidance. This is an estimate only.
          </p>

        </div>
      </div>

    </div>
  </div>

  <!-- ═══ HOW TO USE ═══ -->
  <div slot="how-to-use">
    <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:700; color:var(--text-primary); margin-bottom:0.75rem;">How to use this calculator</h2>
    <p style="color:var(--text-secondary); font-size:0.9rem; line-height:1.75; margin-bottom:0.75rem;">
      Enter your gross annual salary and the drive-away price of the EV you are considering. Adjust the lease term, interest rate, and residual value to match the quote from your novated lease provider. The running costs section lets you input your expected annual charges for charging, insurance, servicing, and registration.
    </p>
    <p style="color:var(--text-secondary); font-size:0.9rem; line-height:1.75; margin-bottom:0.75rem;">
      Click <strong style="color:var(--text-primary);">Calculate savings</strong> to see a side-by-side comparison of your total out-of-pocket cost under a novated lease versus financing the vehicle yourself after tax. The verdict banner shows your net saving (or cost) over the full lease term.
    </p>
    <p style="color:var(--text-secondary); font-size:0.9rem; line-height:1.75;">
      The comparison assumes the cash purchase is financed at the same interest rate as the novated lease for a fair apples-to-apples comparison. Results are estimates only — always get a formal quote from your employer's novated lease provider and speak to a financial adviser before committing.
    </p>
  </div>

  <!-- ═══ HOW IT WORKS ═══ -->
  <div slot="how-it-works">
    <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:700; color:var(--text-primary); margin-bottom:0.75rem;">How the calculation works</h2>
    <p style="color:var(--text-secondary); font-size:0.9rem; line-height:1.75; margin-bottom:1rem;">
      A novated lease creates savings through three mechanisms that don't apply to a standard car loan.
    </p>
    <div style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1rem;">
      {[
        ['Pre-tax deduction', 'The lease payments (finance + running costs) are deducted from your gross salary before income tax is calculated, reducing your taxable income and therefore your tax bill.'],
        ['FBT exemption for EVs', 'Under the Treasury Laws Amendment (Electric Car Discount) Act 2022, eligible battery electric vehicles and plug-in hybrids are exempt from Fringe Benefits Tax when salary packaged. This removes the largest historical cost of novated leasing.'],
        ['GST saving on purchase', 'When your employer purchases the vehicle, they can claim back the GST (10%) paid on the vehicle price as an Input Tax Credit. This saving is passed on to you, effectively reducing the vehicle cost by 1/11th.'],
        ['Australian income tax rates', 'Tax savings are calculated using 2024–25 individual marginal rates: 0% up to $18,200; 16% $18,201–$45,000; 30% $45,001–$135,000; 37% $135,001–$190,000; 45% above $190,000. Medicare levy of 2% is added to all brackets.'],
      ].map(([label, desc]) => (
        <div style="background:var(--bg-surface); border:1px solid var(--border); border-radius:0.625rem; padding:0.875rem 1rem;">
          <div style="font-size:0.85rem; font-weight:700; color:var(--text-primary); margin-bottom:0.3rem;">{label}</div>
          <p style="font-size:0.82rem; color:var(--text-secondary); margin:0; line-height:1.6;">{desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ═══ FAQ ═══ -->
  <div slot="faq">
    <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:700; color:var(--text-primary); margin-bottom:1.25rem;">Frequently asked questions</h2>
    <div style="display:flex; flex-direction:column; gap:0.75rem;" itemscope itemtype="https://schema.org/FAQPage">
      {[
        {
          q: 'What is a novated lease in Australia?',
          a: 'A novated lease is a three-way agreement between you, your employer, and a finance company. Your employer makes lease payments on your behalf from your pre-tax salary. Because the payments come out before income tax is calculated, you pay less tax — and with eligible EVs now FBT-exempt, the savings are significantly larger than they were for petrol vehicles.',
        },
        {
          q: 'Which EVs are eligible for the FBT exemption?',
          a: 'Under the Electric Car Discount Act 2022, battery electric vehicles (BEVs) and plug-in hybrid electric vehicles (PHEVs) first held on or after 1 July 2022 are exempt from FBT, provided the vehicle\'s value is below the luxury car tax threshold for fuel-efficient vehicles ($91,387 for 2024–25). PHEVs lose their exemption from 1 April 2025. The exemption does not apply to hydrogen fuel cell vehicles currently.',
        },
        {
          q: 'What is FBT and why does it normally apply to novated leases?',
          a: 'Fringe Benefits Tax (FBT) is a tax employers pay on non-cash benefits provided to employees, including the private use of a company car. At the standard rate of 47%, FBT historically made novated leases on petrol cars much less attractive. The EV exemption eliminates this cost entirely for eligible vehicles, which is why the savings for EVs are substantially larger than for petrol or hybrid vehicles.',
        },
        {
          q: 'What is a residual value?',
          a: 'The residual value is the agreed remaining value of the vehicle at the end of the lease term. It is set as a percentage of the vehicle\'s original cost based on ATO effective life guidelines. At the end of the lease you can pay the residual to own the car outright, refinance it, trade it in, or start a new novated lease. A lower residual means higher lease payments but less to pay at the end.',
        },
        {
          q: 'Does my employer need to offer novated leasing?',
          a: 'Yes — novated leasing requires your employer to participate. Most medium and large Australian employers offer it, often through providers like Maxxia, RemServ, SG Fleet, or Fleetcare. If your employer does not currently offer novated leasing, they may be willing to set it up — it costs the employer nothing and reduces their payroll tax liability too.',
        },
        {
          q: 'Are the results in this calculator accurate?',
          a: 'This calculator uses 2024–25 Australian income tax rates and current FBT exemption rules to produce a meaningful estimate. However, actual savings depend on your employer\'s lease provider fees, the exact residual value in your quote, whether GST savings are fully passed on, and your personal tax situation. Always obtain a formal illustration from your novated lease provider and consult a financial adviser before signing.',
        },
      ].map(item => (
        <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"
          style="background:var(--bg-surface); border:1.5px solid var(--border); border-radius:0.875rem; padding:1.1rem 1.25rem;">
          <h3 itemprop="name" style="font-size:0.9rem; font-weight:600; color:var(--text-primary); margin:0 0 0.5rem;">{item.q}</h3>
          <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <p itemprop="text" style="font-size:0.875rem; color:var(--text-secondary); line-height:1.7; margin:0;">{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

</ToolLayout>

<style>
  .ev-grid { grid-template-columns: 1fr; }
  @media (min-width: 680px) {
    .ev-grid { grid-template-columns: 1fr 1fr; }
  }

  .ev-field { display: flex; flex-direction: column; gap: 0.3rem; }
  .ev-label { font-size: 0.78rem; font-weight: 600; color: var(--text-muted); font-family: 'Inter', sans-serif; }

  .ev-input-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--border);
    border-radius: 0.5rem;
    background: var(--bg-surface-2);
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .ev-input-wrap:focus-within { border-color: #1D4ED8; }

  .ev-prefix, .ev-suffix {
    padding: 0 0.6rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-surface-3);
    align-self: stretch;
    display: flex;
    align-items: center;
    border-right: 1px solid var(--border);
    user-select: none;
  }
  .ev-suffix { border-right: none; border-left: 1px solid var(--border); }

  .ev-input {
    flex: 1;
    padding: 0.55rem 0.75rem;
    border: none;
    background: transparent;
    color: var(--text-primary);
    font-size: 0.9rem;
    outline: none;
    width: 100%;
    min-width: 0;
    font-family: 'Fira Code', monospace;
  }

  .ev-select {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 0.5rem;
    background: var(--bg-surface-2);
    color: var(--text-primary);
    font-size: 0.875rem;
    outline: none;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .ev-select:focus { border-color: #1D4ED8; }

  .res-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.25rem 0;
    font-size: 0.82rem;
  }
  .res-lbl { color: var(--text-secondary); }
  .res-val { font-family: 'Fira Code', monospace; font-weight: 600; color: var(--text-primary); white-space: nowrap; }
  .res-val.green { color: #16A34A; }
  .res-val.red   { color: #DC2626; }

  :root.dark .res-val.green { color: #4ADE80; }
  :root.dark .res-val.red   { color: #F87171; }
</style>

<script>
  // ── ATO 2024-25 income tax (including 2% Medicare levy) ───────
  function calcIncomeTax(income: number): number {
    if (income <= 0) return 0;
    let tax = 0;
    // Resident individual brackets
    if (income > 190000)       tax += (income - 190000) * 0.45;
    if (income > 135000)       tax += (Math.min(income, 190000) - 135000) * 0.37;
    if (income > 45000)        tax += (Math.min(income, 135000) - 45000)  * 0.30;
    if (income > 18200)        tax += (Math.min(income, 45000)  - 18200)  * 0.16;
    // Medicare levy 2%
    tax += income * 0.02;
    return Math.max(0, tax);
  }

  // ── Flat rate annuity formula for lease payments ──────────────
  function annuityPayment(principal: number, annualRate: number, years: number): number {
    if (annualRate === 0) return principal / years;
    const r = annualRate / 100;
    return principal * r / (1 - Math.pow(1 + r, -years));
  }

  // ── Format currency ───────────────────────────────────────────
  const fmt = (n: number) =>
    (n < 0 ? '-' : '') + '$' + Math.abs(Math.round(n)).toLocaleString('en-AU');

  // ── DOM refs ──────────────────────────────────────────────────
  const calcBtn        = document.getElementById('calc-btn')!;
  const emptyState     = document.getElementById('empty-state')!;
  const resultsContent = document.getElementById('results-content')!;

  function get(id: string): number {
    return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
  }

  // ── Main calculation ──────────────────────────────────────────
  function calculate() {
    const grossSalary   = get('gross-salary');
    const vehiclePrice  = get('vehicle-price');
    const leaseTerm     = get('lease-term');
    const annualKm      = get('annual-km');
    const interestRate  = get('interest-rate');
    const residualPct   = get('residual-pct') / 100;

    const annualFuel      = get('fuel-cost');
    const annualInsurance = get('insurance-cost');
    const annualService   = get('service-cost');
    const annualReg       = get('reg-cost');
    const totalRunning    = annualFuel + annualInsurance + annualService + annualReg;

    // ── NOVATED LEASE ──────────────────────────────────────────
    // GST saving: employer claims ITC, passes to employee
    const gstSaving       = vehiclePrice / 11;
    const vehicleExGST    = vehiclePrice - gstSaving;

    // Residual value
    const residualValue   = vehicleExGST * residualPct;

    // Finance component: annuity on (vehicle ex-GST - residual), PV
    const financePrincipal = vehicleExGST - residualValue / Math.pow(1 + interestRate / 100, leaseTerm);
    const annualFinance    = annuityPayment(financePrincipal, interestRate, leaseTerm);

    // Total annual pre-tax lease package (finance + running costs)
    const annualPreTax     = annualFinance + totalRunning;

    // Taxable income after pre-tax deduction
    const taxableIncome    = Math.max(0, grossSalary - annualPreTax);

    // Tax on normal income vs reduced income
    const taxWithoutLease  = calcIncomeTax(grossSalary);
    const taxWithLease     = calcIncomeTax(taxableIncome);
    const annualTaxSaving  = taxWithoutLease - taxWithLease;

    // FBT: $0 (EV exempt)
    // Running costs are pre-tax so after-tax equivalent is 0 extra
    // Post-tax running = 0 (already pre-tax deducted)

    // Total out-of-pocket over lease term (pre-tax deductions - tax saving - GST saving)
    const leaseTotalCost = (annualPreTax * leaseTerm) - (annualTaxSaving * leaseTerm) - gstSaving;

    // ── CASH / OWN FINANCE ────────────────────────────────────
    // Same rate loan, same term, on full vehicle price (no GST ITC)
    const cashAnnualLoan   = annuityPayment(vehiclePrice - residualValue * (1 + residualPct * 0.1), interestRate, leaseTerm);
    // Running costs paid from after-tax income
    const cashTotalCost    = (cashAnnualLoan + totalRunning) * leaseTerm;

    // ── NET SAVING ────────────────────────────────────────────
    const netSaving = cashTotalCost - leaseTotalCost;
    const isAhead   = netSaving > 0;

    // ── RENDER ────────────────────────────────────────────────
    emptyState.style.display   = 'none';
    resultsContent.style.display = 'flex';

    // Verdict
    const banner = document.getElementById('verdict-banner')!;
    banner.style.background   = isAhead ? '#F0FDF4' : '#FEF2F2';
    banner.style.border        = isAhead ? '1.5px solid #BBF7D0' : '1.5px solid #FECACA';
    document.getElementById('verdict-label')!.style.color = isAhead ? '#166534' : '#991B1B';
    document.getElementById('verdict-label')!.textContent = isAhead
      ? `Novated lease saves you over ${leaseTerm} year${leaseTerm > 1 ? 's' : ''}`
      : `Cash purchase is cheaper over ${leaseTerm} year${leaseTerm > 1 ? 's' : ''}`;
    document.getElementById('verdict-amount')!.style.color = isAhead ? '#16A34A' : '#DC2626';
    document.getElementById('verdict-amount')!.textContent = fmt(Math.abs(netSaving));
    document.getElementById('verdict-sub')!.style.color    = isAhead ? '#166534' : '#991B1B';
    document.getElementById('verdict-sub')!.textContent    = isAhead
      ? `~${fmt(netSaving / leaseTerm)} per year after tax`
      : `Novated lease costs more in this scenario`;

    // Lease column
    (document.getElementById('r-lease-pretax') as HTMLElement).textContent = fmt(annualPreTax * leaseTerm);
    (document.getElementById('r-lease-running') as HTMLElement).textContent = '$0 (pre-tax)';
    (document.getElementById('r-gst-saving')   as HTMLElement).textContent = fmt(gstSaving);
    (document.getElementById('r-lease-total')  as HTMLElement).textContent = fmt(leaseTotalCost);

    // Cash column
    (document.getElementById('r-cash-loan')    as HTMLElement).textContent = fmt(cashAnnualLoan * leaseTerm);
    (document.getElementById('r-cash-running') as HTMLElement).textContent = fmt(totalRunning * leaseTerm);
    (document.getElementById('r-cash-total')   as HTMLElement).textContent = fmt(cashTotalCost);

    // Tax breakdown (annual)
    (document.getElementById('r-gross')       as HTMLElement).textContent = fmt(grossSalary);
    (document.getElementById('r-pretax-ded')  as HTMLElement).textContent = `-${fmt(annualPreTax)}`;
    (document.getElementById('r-taxable')     as HTMLElement).textContent = fmt(taxableIncome);
    (document.getElementById('r-tax-saved')   as HTMLElement).textContent = fmt(annualTaxSaving);
    (document.getElementById('r-gst2')        as HTMLElement).textContent = fmt(gstSaving);
  }

  calcBtn.addEventListener('click', calculate);

  // Run on load with defaults
  calculate();
</script>
