---
import BaseLayout from './BaseLayout.astro';
import tools from '../data/tools.json';

interface Props {
  tool: {
    slug: string;
    name: string;
    description: string;
    category: string;
    tags: string[];
    icon: string;
    dateAdded: string;
  };
}

const { tool } = Astro.props;
const adsenseId = 'ca-pub-XXXXXXXXXXXXXXXX'; // ← Same as BaseLayout

// Related tools: same category first, then by tag overlap
const relatedTools = tools
  .filter(t => t.slug !== tool.slug)
  .map(t => ({
    ...t,
    score:
      (t.category === tool.category ? 3 : 0) +
      t.tags.filter(tag => tool.tags.includes(tag)).length,
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 6);

// Structured data for this tool
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": tool.name,
  "description": tool.description,
  "url": `https://yoursite.com/tools/${tool.slug}`,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "datePublished": tool.dateAdded,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://yoursite.com" },
      { "@type": "ListItem", "position": 2, "name": tool.category, "item": `https://yoursite.com/category/${tool.category}` },
      { "@type": "ListItem", "position": 3, "name": tool.name }
    ]
  }
};
---

<BaseLayout
  title={`${tool.name} – Free Online Tool | ToolBox`}
  description={tool.description}
  canonicalUrl={`/tools/${tool.slug}`}
  ogType="website"
  structuredData={structuredData}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Breadcrumb (SEO + UX) -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="hover:text-indigo-600 transition-colors">Home</a></li>
        <li class="text-gray-300">›</li>
        <li><a href={`/category/${tool.category}`} class="hover:text-indigo-600 transition-colors capitalize">{tool.category.replace('-', ' ')}</a></li>
        <li class="text-gray-300">›</li>
        <li class="text-gray-800 font-medium">{tool.name}</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

      <!-- LEFT SIDEBAR (desktop): Category nav + ad -->
      <aside class="hidden lg:block lg:col-span-2">
        <div class="sticky top-24 space-y-6">

          <!-- Category quick nav -->
          <div class="bg-white rounded-xl border border-gray-200 p-4">
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Categories</h3>
            <nav class="space-y-1">
              {(['calculators','converters','health','web-tools','estimators']).map(cat => (
                <a
                  href={`/category/${cat}`}
                  class={`block px-3 py-1.5 rounded-lg text-sm transition-colors capitalize ${tool.category === cat ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}`}
                >
                  {cat.replace('-', ' ')}
                </a>
              ))}
            </nav>
          </div>

          <!-- Left sidebar ad (160x600 skyscraper) -->
          <div class="flex justify-center">
            <ins
              class="adsbygoogle"
              style="display:inline-block;width:160px;height:600px"
              data-ad-client={adsenseId}
              data-ad-slot="2345678901"
              aria-label="Advertisement"
            ></ins>
          </div>

        </div>
      </aside>

      <!-- MAIN CONTENT -->
      <article class="lg:col-span-7">

        <!-- Tool header -->
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-4xl">{tool.icon}</span>
            <div>
              <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{tool.name}</h1>
              <p class="text-gray-500 text-sm mt-0.5">{tool.description}</p>
            </div>
          </div>
        </div>

        <!-- THE TOOL (injected by each tool's page) -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 mb-8">
          <slot name="tool" />
        </div>

        <!-- ✦ AD SLOT: Below tool output — HIGHEST CTR position -->
        <!-- Only shows AFTER user interacts; naturally follows result delivery -->
        <div class="flex justify-center my-6">
          <ins
            class="adsbygoogle"
            style="display:block"
            data-ad-client={adsenseId}
            data-ad-slot="3456789012"
            data-ad-format="auto"
            data-full-width-responsive="true"
            aria-label="Advertisement"
          ></ins>
        </div>

        <!-- How to use — SEO content zone -->
        <div class="prose prose-gray max-w-none mb-8">
          <slot name="how-to-use" />
        </div>

        <!-- How it works — SEO content zone -->
        <div class="bg-gray-50 rounded-xl border border-gray-100 p-6 mb-8">
          <slot name="how-it-works" />
        </div>

        <!-- FAQ — great for featured snippets -->
        <div class="mb-8">
          <slot name="faq" />
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-8">
          {tool.tags.map(tag => (
            <span class="px-3 py-1 bg-indigo-50 text-indigo-700 rounded-full text-xs font-medium">
              {tag}
            </span>
          ))}
        </div>

      </article>

      <!-- RIGHT SIDEBAR: Ads + related tools -->
      <aside class="lg:col-span-3">
        <div class="sticky top-24 space-y-6">

          <!-- Right sidebar ad (300x250 rectangle — highest RPM for tool sites) -->
          <div class="flex justify-center">
            <ins
              class="adsbygoogle"
              style="display:inline-block;width:300px;height:250px"
              data-ad-client={adsenseId}
              data-ad-slot="4567890123"
              aria-label="Advertisement"
            ></ins>
          </div>

          <!-- Related tools -->
          <div class="bg-white rounded-xl border border-gray-200 p-4">
            <h2 class="text-sm font-semibold text-gray-700 mb-3">Related Tools</h2>
            <div class="space-y-2">
              {relatedTools.map(related => (
                <a
                  href={`/tools/${related.slug}`}
                  class="flex items-center gap-3 p-2 rounded-lg hover:bg-indigo-50 transition-colors group"
                >
                  <span class="text-xl shrink-0">{related.icon}</span>
                  <span class="text-sm text-gray-700 group-hover:text-indigo-700 font-medium leading-tight">
                    {related.name}
                  </span>
                </a>
              ))}
            </div>
          </div>

          <!-- Second sidebar ad (300x250) -->
          <div class="flex justify-center">
            <ins
              class="adsbygoogle"
              style="display:inline-block;width:300px;height:250px"
              data-ad-client={adsenseId}
              data-ad-slot="5678901234"
              aria-label="Advertisement"
            ></ins>
          </div>

        </div>
      </aside>

    </div>

    <!-- Related tools grid (below fold — mobile-friendly) -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <h2 class="text-xl font-bold text-gray-900 mb-6">More Tools You Might Like</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {relatedTools.map(related => (
          <a
            href={`/tools/${related.slug}`}
            class="flex flex-col items-center text-center p-4 bg-white rounded-xl border border-gray-200 hover:border-indigo-300 hover:shadow-md transition-all group"
          >
            <span class="text-3xl mb-2">{related.icon}</span>
            <span class="text-xs font-medium text-gray-700 group-hover:text-indigo-700 leading-tight">
              {related.name}
            </span>
          </a>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>

<script>
  // Push all ads on this page
  document.querySelectorAll('.adsbygoogle').forEach(() => {
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  });
</script>
